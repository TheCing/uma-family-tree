{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "~/*": ["../*"]
    }
  },
  "include": [
    "**/*.ts",
    "types/**/*.ts",
    "../frontend/src/types/characterNameId.ts",
    "../frontend/src/types/dressData.ts",
    "../frontend/src/types/relation.ts",
    "../frontend/src/types/textData.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
